# =============================================================================
# FutureShield AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The app reads these variables at module-import time, so load_dotenv() must
# fire before any imports that consume env vars. main.py handles this ordering
# correctly (the fix to the bootstrap race condition).
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED: API Access Token
# ---------------------------------------------------------------------------
# Bearer token that all /api/* requests must include in the Authorization
# header. Choose a strong, random value.
#
#   In requests:  Authorization: Bearer <API_ACCESS_TOKEN>
#   In SSE:       ?token=<API_ACCESS_TOKEN>
#   In tests:     Bearer shield-admin-pass
#
API_ACCESS_TOKEN=shield-admin-pass

# ---------------------------------------------------------------------------
# OPTIONAL: Google Gemini API Key
# ---------------------------------------------------------------------------
# Used for AI-powered features: goal decomposition, smart summaries, threat
# analysis, future simulations, rescue missions, and the digital twin.
#
# Get a free key: https://aistudio.google.com/apikey
#
# When NOT configured, the app runs in offline mode. All AI endpoints still
# respond using hardcoded fallback data instead of calling Gemini.
#
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL: SQLite Database Path
# ---------------------------------------------------------------------------
# Full path to the SQLite database file. Defaults to database.db in the
# project root if not set.
#
# Useful for pointing at a persistent DB outside the project directory or
# isolating test databases (the test suite sets this automatically).
#
# FUTURESHIELD_DB_PATH=C:\datautureshield_prod.db
